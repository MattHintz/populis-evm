BASE_SEPOLIA_RPC_URL=
BASE_MAINNET_RPC_URL=https://mainnet.base.org
DEPLOYER_PRIVATE_KEY=

# deploy-emitter.js — optional overrides
# If omitted, uses pinned testnet11 bridge policy hash from deploy script.
BRIDGE_POLICY_HASH=
# Set ZKPASSPORT_DOMAIN to deploy the real ZkPassportRealVerifierAdapter.
# For alpha testnet: ZKPASSPORT_DOMAIN=populis.app ZKPASSPORT_DEV_MODE=true
# Accepts mock "Zero Knowledge Republic" passports when devMode=true.
ZKPASSPORT_DOMAIN=
ZKPASSPORT_DEV_MODE=false
# Or skip adapter deploy entirely by pointing to a pre-deployed adapter.
ZKPASSPORT_VERIFIER_ADDR=
